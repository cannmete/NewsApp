@{
    ViewData["Title"] = "Yeni Haber Yaz";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script>
    const userToken = localStorage.getItem("token");
    if (!userToken) { window.location.href = "/Auth/Login"; }
    else {
        function parseJwt(t) { try { return JSON.parse(atob(t.split('.')[1])); } catch (e) { return null; } }
        let role = parseJwt(userToken)["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || "User";
        if (Array.isArray(role)) role = role[0];
        if (role === "User") {
            alert("Haber yazma yetkiniz yok.");
            window.location.href = "/Home/Index";
        }
    }
</script>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4">
                    <h3 class="mb-0" id="pageHeaderTitle"><i class="fas fa-pen-fancy me-2"></i>Yeni Haber Oluştur</h3>
                    <p class="mb-0 text-white-50 mt-1">Okuyucularınızla en güncel ve detaylı gelişmeleri paylaşın.</p>
                </div>

                <div class="card-body p-5">
                    <div class="row">
                        <div class="col-md-8 mb-4">
                            <label class="form-label fw-bold text-secondary">Haber Başlığı</label>
                            <input type="text" id="txtTitle" class="form-control form-control-lg bg-light border-0" placeholder="Çarpıcı bir başlık girin...">
                        </div>
                        <div class="col-md-4 mb-4">
                            <label class="form-label fw-bold text-secondary">Kategori</label>
                            <select id="ddlCategory" class="form-select form-select-lg bg-light border-0">
                                <option value="">Seçiniz...</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary">Haber İçeriği</label>
                        <textarea id="txtContent" class="form-control bg-light border-0" rows="12" placeholder="Haberin detaylarını buraya dökün... Enter tuşu ile paragraflar oluşturabilirsiniz."></textarea>
                    </div>

                    <h5 class="fw-bold mt-5 mb-3 border-bottom pb-2"><i class="fas fa-images text-primary me-2"></i>Haber Görselleri</h5>

                    <div class="row g-4 mb-4">
                        <div class="col-md-12">
                            <label class="form-label small fw-bold text-muted">Kapak Fotoğrafı (Zorunlu)</label>
                            <div class="d-flex align-items-start gap-3">
                                <div class="flex-grow-1">
                                    <input type="file" id="fileImg1" class="form-control bg-light border-0" accept="image/*">
                                </div>
                                <div id="previewContainer1" class="position-relative shadow-sm rounded" style="display:none; width: 120px; height: 80px; background:#f8f9fa;">
                                    <img id="previewImg1" src="" class="w-100 h-100 rounded" style="object-fit: cover;">
                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 translate-middle rounded-circle shadow" style="width: 25px; height: 25px; padding: 0;" onclick="removeImage(1)">
                                        <i class="fas fa-times" style="font-size: 10px;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Ek Görsel 2</label>
                            <div class="d-flex align-items-start gap-2">
                                <input type="file" id="fileImg2" class="form-control bg-light border-0 flex-grow-1" accept="image/*">
                                <div id="previewContainer2" class="position-relative shadow-sm rounded flex-shrink-0" style="display:none; width: 60px; height: 40px; background:#f8f9fa;">
                                    <img id="previewImg2" src="" class="w-100 h-100 rounded" style="object-fit: cover;">
                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 translate-middle rounded-circle shadow" style="width: 20px; height: 20px; padding: 0;" onclick="removeImage(2)">
                                        <i class="fas fa-times" style="font-size: 9px;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Ek Görsel 3</label>
                            <div class="d-flex align-items-start gap-2">
                                <input type="file" id="fileImg3" class="form-control bg-light border-0 flex-grow-1" accept="image/*">
                                <div id="previewContainer3" class="position-relative shadow-sm rounded flex-shrink-0" style="display:none; width: 60px; height: 40px; background:#f8f9fa;">
                                    <img id="previewImg3" src="" class="w-100 h-100 rounded" style="object-fit: cover;">
                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 translate-middle rounded-circle shadow" style="width: 20px; height: 20px; padding: 0;" onclick="removeImage(3)">
                                        <i class="fas fa-times" style="font-size: 9px;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Ek Görsel 4</label>
                            <div class="d-flex align-items-start gap-2">
                                <input type="file" id="fileImg4" class="form-control bg-light border-0 flex-grow-1" accept="image/*">
                                <div id="previewContainer4" class="position-relative shadow-sm rounded flex-shrink-0" style="display:none; width: 60px; height: 40px; background:#f8f9fa;">
                                    <img id="previewImg4" src="" class="w-100 h-100 rounded" style="object-fit: cover;">
                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 translate-middle rounded-circle shadow" style="width: 20px; height: 20px; padding: 0;" onclick="removeImage(4)">
                                        <i class="fas fa-times" style="font-size: 9px;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Ek Görsel 5</label>
                            <div class="d-flex align-items-start gap-2">
                                <input type="file" id="fileImg5" class="form-control bg-light border-0 flex-grow-1" accept="image/*">
                                <div id="previewContainer5" class="position-relative shadow-sm rounded flex-shrink-0" style="display:none; width: 60px; height: 40px; background:#f8f9fa;">
                                    <img id="previewImg5" src="" class="w-100 h-100 rounded" style="object-fit: cover;">
                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 translate-middle rounded-circle shadow" style="width: 20px; height: 20px; padding: 0;" onclick="removeImage(5)">
                                        <i class="fas fa-times" style="font-size: 9px;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="text-end mt-5">
                        <button id="btnPublish" class="btn btn-success btn-lg px-5 shadow rounded-pill">
                            <i class="fas fa-paper-plane me-2"></i>Haberi Yayımla
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

    <style>
        .ck-editor__editable_inline {
            min-height: 300px;
            font-size: 1.1rem;
        }
    </style>

    <script>
        $(document).ready(function () {
            const token = localStorage.getItem("token");
            if (!token) { window.location.href = "/Auth/Login"; return; }

            let myEditor;
            let existingNews = null;

            const urlParams = new URLSearchParams(window.location.search);
            const editId = urlParams.get('id');

            // --- 1. GÖRSEL ÖNİZLEME VE SİLME FONKSİYONLARI ---

            // Dosya seçildiğinde anında önizleme göster
            function setupImagePreview(index) {
                $(`#fileImg${index}`).change(function () {
                    const file = this.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            $(`#previewImg${index}`).attr("src", e.target.result);
                            $(`#previewContainer${index}`).fadeIn('fast');
                        }
                        reader.readAsDataURL(file);
                    }
                });
            }

            for (let i = 1; i <= 5; i++) setupImagePreview(i);

            // Çarpıya basılınca görseli temizle
            window.removeImage = function(index) {
                $(`#fileImg${index}`).val(""); // Seçili dosyayı inputtan sil
                $(`#previewImg${index}`).attr("src", ""); // Önizlemeyi boşalt
                $(`#previewContainer${index}`).fadeOut('fast'); // Kutuyu gizle
            }

            // --- 2. CKEDITOR VE VERİ ÇEKME ---
            ClassicEditor
                .create(document.querySelector('#txtContent'), {
                    toolbar: [ 'heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo' ]
                })
                .then(editor => {
                    myEditor = editor;

                    if (editId) {
                        $("#pageHeaderTitle").html('<i class="fas fa-edit text-warning me-2"></i>Haberi Düzenle');
                        $("#btnPublish").html('<i class="fas fa-save me-2"></i>Değişiklikleri Kaydet').removeClass("btn-success").addClass("btn-primary");

                        $.ajax({
                            url: "https://localhost:7112/api/News/" + editId,
                            type: "GET",
                            success: function(res) {
                                existingNews = res.data ? res.data : (res.$values ? res.$values : res);

                                $("#txtTitle").val(existingNews.title);
                                myEditor.setData(existingNews.content);
                                setTimeout(() => { $("#ddlCategory").val(existingNews.categoryId); }, 500);

                                // Mevcut görselleri önizleme alanlarına doldur
                                const imgPaths = [existingNews.imagePath, existingNews.imagePath2, existingNews.imagePath3, existingNews.imagePath4, existingNews.imagePath5];

                                imgPaths.forEach((path, i) => {
                                    let index = i + 1;
                                    if (path) {
                                        $(`#previewImg${index}`).attr("src", path);
                                        $(`#previewContainer${index}`).show();
                                    }
                                });
                            }
                        });
                    }
                }).catch(error => console.error(error));

            // --- 3. KATEGORİLERİ DOLDUR ---
            $.ajax({
                url: "https://localhost:7112/api/Category", type: "GET",
                success: function (res) {
                    let catList = res.data ? res.data : (res.$values ? res.$values : res);
                    let opts = '<option value="">Kategori Seçiniz...</option>';
                    $.each(catList, function (i, c) { opts += `<option value="${c.id || c.Id}">${c.name || c.Name}</option>`; });
                    $("#ddlCategory").html(opts);
                }
            });

            // --- 4. YAYIMLA VEYA GÜNCELLE İŞLEMİ ---
            $("#btnPublish").click(async function () {
                let title = $("#txtTitle").val();
                let catId = parseInt($("#ddlCategory").val());
                let content = myEditor.getData();

                if (!title || !content || isNaN(catId)) {
                    Swal.fire("Uyarı", "Başlık, Kategori ve İçerik zorunludur.", "warning"); return;
                }

                let btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> İşleniyor...');

                // Akıllı Yükleme Fonksiyonu: Yeni dosya varsa yükler, yoksa önizlemedeki eski linki korur, çarpıya basıldıysa null döndürür.
                async function resolveImageUrl(inputId, index) {
                    let file = document.getElementById(inputId).files[0];
                    if (file) {
                        let fd = new FormData(); fd.append("file", file);
                        try {
                            let r = await $.ajax({ url: "https://localhost:7112/api/News/Upload", type: "POST", headers: { "Authorization": "Bearer " + token }, data: fd, processData: false, contentType: false });
                            return r.url;
                        } catch (e) { return null; }
                    }

                    // Dosya seçilmemişse önizleme kutusuna bak. Doluysa eski resmi koru.
                    let previewSrc = $(`#previewImg${index}`).attr("src");
                    if (previewSrc && !previewSrc.startsWith("data:")) return previewSrc;

                    return null; // Silinmiş veya hiç yüklenmemiş
                }

                let p = {
                    title: title,
                    content: content,
                    categoryId: catId,
                    imagePath: await resolveImageUrl("fileImg1", 1),
                    imagePath2: await resolveImageUrl("fileImg2", 2),
                    imagePath3: await resolveImageUrl("fileImg3", 3),
                    imagePath4: await resolveImageUrl("fileImg4", 4),
                    imagePath5: await resolveImageUrl("fileImg5", 5)
                };

                // Kapak görseli kontrolü
                if (!p.imagePath) {
                    Swal.fire("Uyarı", "Kapak Fotoğrafı zorunludur! Mevcut olanı sildiyseniz yenisini yüklemelisiniz.", "warning");
                    btn.prop("disabled", false).html(editId ? '<i class="fas fa-save me-2"></i>Değişiklikleri Kaydet' : '<i class="fas fa-paper-plane me-2"></i>Haberi Yayımla');
                    return;
                }

                if (editId) p.id = parseInt(editId);

                let requestType = editId ? "PUT" : "POST";
                let apiUrl = editId ? "https://localhost:7112/api/News/" + editId : "https://localhost:7112/api/News";

                $.ajax({
                    url: apiUrl,
                    type: requestType,
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(p),
                    success: function () {
                        Swal.fire("Başarılı!", editId ? "Haber başarıyla güncellendi." : "Haber yayımlandı.", "success").then(() => window.location.href = "/Home/Profile");
                    },
                    error: function () {
                        btn.prop("disabled", false).html(editId ? '<i class="fas fa-save me-2"></i>Değişiklikleri Kaydet' : '<i class="fas fa-paper-plane me-2"></i>Haberi Yayımla');
                        Swal.fire("Hata", "İşlem gerçekleştirilemedi.", "error");
                    }
                });
            });
        });
    </script>
}