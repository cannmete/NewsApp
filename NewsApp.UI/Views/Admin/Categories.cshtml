@{
    ViewData["Title"] = "Kategori Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card p-4 shadow-sm border-0">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold"><i class="fas fa-folder-open text-primary me-2"></i> Kategori Listesi</h5>
                <button class="btn btn-success" onclick="openAddModal()">
                    <i class="fas fa-plus me-1"></i> Yeni Kategori
                </button>
            </div>
            <hr />
            <table class="table table-hover table-bordered mt-2">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Kategori Adı</th>
                        <th>Açıklama</th>
                        <th class="text-center" style="width: 200px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="categoryTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Kategori İşlemi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="txtCategoryId" value="0" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Kategori Adı</label>
                    <input type="text" id="txtCategoryName" class="form-control" placeholder="Örn: Teknoloji">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Açıklama</label>
                    <textarea id="txtCategoryDescription" class="form-control" rows="3" placeholder="Kategori hakkında kısa bilgi..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                <button type="button" class="btn btn-primary" id="btnSaveCategory">
                    <i class="fas fa-save me-1"></i> Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const apiUrl = "https://localhost:7112/api/Category"; // Kendi portunla eşleştiğinden emin ol
            let categoryModal = new bootstrap.Modal(document.getElementById('categoryModal'));

            // 1. KATEGORİLERİ GETİR (GET)
            function LoadCategories() {
                $.ajax({
                    url: apiUrl,
                    type: "GET",
                    success: function (response) {
                        let html = "";
                        $.each(response, function (index, item) {
                            // Büyük/küçük harf duyarlılığı kontrolü
                            let catId = item.id || item.Id;
                            let catName = item.name || item.Name;
                            let catDesc = item.description || item.Description || "-";

                            html += `<tr>
                                        <td><small class="text-muted">${catId}</small></td>
                                        <td><strong>${catName}</strong></td>
                                        <td>${catDesc}</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-warning btn-edit me-1"
                                                    data-id="${catId}"
                                                    data-name="${catName}"
                                                    data-desc="${catDesc}">
                                                <i class="fas fa-edit"></i> Düzenle
                                            </button>
                                            <button class="btn btn-sm btn-danger btn-delete" data-id="${catId}">
                                                <i class="fas fa-trash"></i> Sil
                                            </button>
                                        </td>
                                     </tr>`;
                        });
                        $("#categoryTableBody").html(html);
                    },
                    error: function (err) {
                        console.log("Yükleme Hatası:", err);
                        Swal.fire("Uyarı", "Veriler yüklenemedi.", "error");
                    }
                });
            }

            LoadCategories();

            // Modalı Ekleme Modunda Aç
            window.openAddModal = function () {
                $("#modalTitle").text("Yeni Kategori Ekle");
                $("#txtCategoryId").val("0"); // Yeni kayıt olduğunu 0 ile belirtiyoruz
                $("#txtCategoryName").val("");
                $("#txtCategoryDescription").val("");
                categoryModal.show();
            };

            // Modalı Düzenleme Modunda Aç (Event Delegation)
            $("#categoryTableBody").on("click", ".btn-edit", function () {
                $("#modalTitle").text("Kategori Güncelle");
                $("#txtCategoryId").val($(this).attr("data-id"));
                $("#txtCategoryName").val($(this).attr("data-name"));
                $("#txtCategoryDescription").val($(this).attr("data-desc") !== "-" ? $(this).attr("data-desc") : "");
                categoryModal.show();
            });

            // 2 & 3. KAYDET VEYA GÜNCELLE (POST & PUT)
            $("#btnSaveCategory").click(function () {
                let id = parseInt($("#txtCategoryId").val());
                let name = $("#txtCategoryName").val().trim();
                let desc = $("#txtCategoryDescription").val().trim();

                if (name === "") {
                    Swal.fire("Uyarı", "Kategori adı boş olamaz.", "warning");
                    return;
                }

                let payload = {
                    id: id,
                    name: name,
                    description: desc,
                    isActive: true
                };

                let ajaxType = id === 0 ? "POST" : "PUT";
                let targetUrl = id === 0 ? apiUrl : apiUrl + "/" + id;

                $.ajax({
                    url: targetUrl,
                    type: ajaxType,
                    contentType: "application/json",
                    data: JSON.stringify(payload),
                    success: function (res) {
                        categoryModal.hide();
                        Swal.fire("Başarılı", id === 0 ? "Kategori eklendi." : "Kategori güncellendi.", "success");
                        LoadCategories();
                    },
                    error: function (err) {
                        console.log("İşlem Hatası:", err);
                        Swal.fire("Uyarı", "İşlem sırasında bir hata oluştu.", "error");
                    }
                });
            });

            // 4. KATEGORİ SİL (DELETE)
            $("#categoryTableBody").on("click", ".btn-delete", function () {
                let id = $(this).attr("data-id");

                Swal.fire({
                    title: 'Emin misiniz?',
                    text: "Bu kategoriyi kalıcı olarak silmek üzeresiniz.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Sil',
                    cancelButtonText: 'Vazgeç'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: apiUrl + "/" + id,
                            type: "DELETE",
                            success: function () {
                                Swal.fire("Başarılı", "Kategori silindi.", "success");
                                LoadCategories();
                            },
                            error: function (err) {
                                console.log("Silme Hatası:", err);
                                Swal.fire("Uyarı", "Silme işlemi başarısız.", "error");
                            }
                        });
                    }
                });
            });
        });
    </script>
}